# OZE-Agent — Environment Template
#
# CONVENTION (post-Phase-0.8, 26.04.2026):
# Prod secrets żyją w Railway env vars (`railway variables --set ...`).
# Local dev: `railway run -e production python -m bot` zaciąga env z Railway live.
# Lokalny `.env` z prawdziwymi wartościami NIE jest już używany.
#
# Ten plik to TYLKO szablon dokumentujący wymagane env vars.
# NIE wpisuj tu prawdziwych wartości i NIE zmieniaj nazwy na `.env`.

# === Core ===
TELEGRAM_BOT_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ENV=production                 # production | development | test

# === Google OAuth ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# === Supabase (project: AgentOZE production) ===
SUPABASE_URL=
SUPABASE_KEY=                  # anon key (public-safe)
SUPABASE_SERVICE_KEY=          # service_role JWT — bypassuje RLS, BARDZO sekretne
SUPABASE_JWT_SECRET=           # do walidacji user JWT — BARDZO sekretne

# === Security ===
ENCRYPTION_KEY=                # Fernet key, format: base64-encoded 32 bytes
                               # UWAGA: rotacja wymaga re-encrypt wszystkich Google tokens (Phase 3 planu)
BILLING_INTERNAL_SECRET=       # shared HMAC secret: Vercel webhook -> FastAPI billing

# === Pricing (jawne, nie sekretne) ===
ACTIVATION_FEE_PLN=0
ACTIVATION_FEE_PROMO_PLN=0
MONTHLY_SUBSCRIPTION_PLN=399
YEARLY_SUBSCRIPTION_PLN=350

# === Monitoring ===
SENTRY_DSN=

# === Admin ===
ADMIN_TELEGRAM_ID=
ADMIN_EMAIL=admin@agent-oze.pl
OWNER_ADMIN_EMAILS=admin@agent-oze.pl              # comma-separated emails allowed to open /admin

# === Admin mirror (owner Sheets + owner Calendar) ===
ADMIN_MIRROR_ENABLED=false
ADMIN_MIRROR_GOOGLE_USER_ID=      # users.id konta admina z podpiętym Google OAuth
ADMIN_MIRROR_SPREADSHEET_ID=      # arkusz właścicielski z zakładkami mirroru
ADMIN_MIRROR_CALENDAR_ID=         # zbiorczy Google Calendar na przyszłe appointmenty
USER_PROFILE_AGENT_ENABLED=false  # nocny admin-only agent profilujący użytkowników

# === URLs ===
BASE_URL=
DASHBOARD_URL=
ADMIN_URL=

# === Email (SMTP — używane przez bot do email notyfikacji, jeśli jest) ===
GMAIL_SMTP_USER=
GMAIL_SMTP_PASSWORD=           # Google App Password, NIE konto password

# === Misc ===
TIMEZONE=Europe/Warsaw
DAILY_INTERACTION_LIMIT=

# === Stripe (billing & subscriptions) ===
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# === Legacy ===
# Przelewy24 zastąpione przez Stripe (Phase 2 planu, migracja 0002).
# Klucze PRZELEWY24_* zostały usunięte 26.04.2026.
