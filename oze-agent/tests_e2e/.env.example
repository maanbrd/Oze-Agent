# ── Phase 7 E2E harness environment ───────────────────────────────────────────
# Copy to tests_e2e/.env (gitignored) and fill. Do NOT commit the filled file.
# See tests_e2e/README.md for full setup.

# Telethon credentials for the TEST user account.
# Obtain at https://my.telegram.org/apps for that account.
TELEGRAM_E2E_API_ID=
TELEGRAM_E2E_API_HASH=

# Bot to test. Use @username for prod or @staging_bot for a staging deploy.
TELEGRAM_E2E_BOT_USERNAME=@OzeAgentBot

# Numeric Telegram user id of the test account. MUST match the bot's
# ADMIN_TELEGRAM_ID for admin-gated commands (e.g. /debug_brief) to work.
TELEGRAM_E2E_ADMIN_ID=

# Path prefix for Telethon session storage. First interactive login creates
# <prefix>.session; subsequent runs are silent. Keep under .sessions/ so
# the file is gitignored.
TELEGRAM_E2E_SESSION=tests_e2e/.sessions/e2e

# Optional — override the PASS/FAIL report location.
# TELEGRAM_E2E_REPORT=test_results_e2e.md
